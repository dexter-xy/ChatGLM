{
  "name": "ChatGLM-WebApp",
  "version": "v1.0.0",
  "description": "基于ChatGLM的网页对话应用",
  "workspaces": [
    "api",
    "client"
  ],
  "scripts": {
    "backend": "cross-env NODE_ENV=production node api/server/index.js",
    "backend:dev": "cross-env NODE_ENV=development npx nodemon api/server/index.js",
    "frontend": "cd client && npm run build",
    "frontend:dev": "cd client && npm run dev",
    "start": "npm run backend",
    "dev": "concurrently \"npm run backend:dev\" \"npm run frontend:dev\"",
    "build": "npm run frontend",
    "test": "npm run test:api && npm run test:client",
    "test:api": "cd api && npm run test",
    "test:client": "cd client && npm run test",
    "lint": "eslint \"{api,client}/**/*.{js,jsx,ts,tsx}\"",
    "lint:fix": "eslint --fix \"{api,client}/**/*.{js,jsx,ts,tsx}\""
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dexter-xy/ChatGLM-WebApp.git"
  },
  "keywords": ["chatglm", "ai", "chat", "conversation", "web-app"],
  "author": "dexter-xy",
  "license": "MIT",
  "bugs": {
    "url": "https://github.com/dexter-xy/ChatGLM-WebApp/issues"
  },
  "homepage": "https://github.com/dexter-xy/ChatGLM-WebApp",
  "devDependencies": {
    "concurrently": "^7.6.0",
    "cross-env": "^7.0.3",
    "eslint": "^9.20.1",
    "nodemon": "^3.0.3"
  }
}